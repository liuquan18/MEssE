#
# ICON Seamless AMIP test experiment
#
# author_list='AS, DWD'
#
# Script order follows atm_qubicc_test runscripts by Marco Giorgetta used in icon aes
# 
# amip present-day simulation with transient atmosphere and land conditions
# used for
#     - SST and sea ice
#     - spectral solar irradiation (?)
#     - well mixed greenhouse gases CO2, CH4, N2O, CFCs
#     - O3 concentrations
#     - Kinne aerosols 
#     - Volcano aerosols
#
#     - r2b4 for atm / no use of reduced radiation grid
#     - if reduced rad is wanted, 
#       please set : latm_above_top = .true. # extra layer above model top
#                    lredgrid_phys  = .true. # switch on usage of reduced rad grid  
#                    radiation_grid_filename = ${atmo_rad_grid}
#
# Technical setup
# 
# - no_of_nodes          = number of nodes
# - mpi_procs_pernode    = processes/node
# - mpi_total_procs      = number of processes = no_of_nodes * mpi_procs_pernode
#                          --> start ICON mpi_total_procs times
#
# - num_io_procs         = number of output processes
#                          --> parallel_nml/num_io_procs
#
# --> number of compute processes = mpi_total_procs - num_io_procs
#
# - nproma / nblocks_c   : determine the main blocking length and inner loop lengths
#                          if nblocks_c <= 0 then nproma as specified is used
#                          if nblocks_c >  0 then nproma is computed as (cells on patch - 1)/nblocks_c + 1
#                          --> parallel_nml/nproma
#                          --> parallel_nml/nblocks_c
# 
#--------------------------------------------------------------------------------------------------
#
# Variables provided by the header section (->create_target_header) of the full runscript
# which are used below:
#
# EXPNAME               = name of exp. in 'exp.<name>'
# basedir               = base directory of the ICON repository,
#                         where bin/, experiments/, externals/, and run/ exist
#
# icon_data_rootFolder  = root directory for ICON data
#
# nproma                = blocking length for array dimensioning and inner loop lengths
#                         which is set in run/create_target_header for the used machine
#
# nblocks_c             = number of looping chunks used for cells
#                         which is set in run/create_target_header for the used machine
#--------------------------------------------------------------------------------------------------
#
# Variables required by the executing section (->exec.iconrun) of the full runscript
# which are defined below:
#
# start_date            = start date of the experiment
# end_date              = end date of the experiment
# checkpoint_interval   = interval for writing restart files
# restart_interval      = interval for restarting
# atmo_namelist         = file with namelists for the atmosphere
# jsbach_namelist       = file with namelists for the land
# run_jsbach            = switch for JSBACH land, yes|true:on, else:off
#
#--------------------------------------------------------------------------------------------------
# (1) Define the experimental setup: time frame and output

# horizontal grid(s)
grids_folder=${icon_data_rootFolder}/grids/public/edzw
#
# domain globe
grid_id=0012
grid_refinement=R02B04
grid_label=G
grid_name=icon_grid_${grid_id}_${grid_refinement}_${grid_label}
#
atmo_dyn_grids="'${grid_name}.nc',"



# date+time
start_date=1979-01-01T00:00:00Z
  end_date=1989-01-01T00:00:00Z

# restart intervals
checkpoint_interval=P1Y
   restart_interval=P1Y

# output intervals
output_interval_2d="P1M"      
output_interval_3d="P1M"      
output_interval_pl="P1M"      

#start_date_hfreq="1979-02-01T00:00:00"
#end_date_hfreq="1979-03-01T00:00:00"

file_interval="P1Y"            # one day
file_interval_hfreq="P1M"


# output format
grib_format=2
netcdf_format=4
output_format=${netcdf_format}

# options for NetCDF format:
if [ ${output_format} -eq ${netcdf_format} ]
then
#
# include (.TRUE.) or exclude (.FALSE.) lon/lat grid data in output files
output_grid=.FALSE.          # used in output_nml
#
# 64bit (.TRUE.) or 32bit (.FALSE.) floating point format
flt64_output=.TRUE.        # used in io_nml
#
fi

# options for GRIB format:
if [ ${output_format} -eq ${grib_format} ]
then
#
# exclude (.FALSE.) grid data (lon/lat) in output files
output_grid=.FALSE.         # used in output_nml
#
# standard (.FALSE.) or ccsds compressed (.TRUE.) GRIB format
compress_ccsds=.FALSE.      # used in gribout_nml
#
fi

# output control
# - files are produced for every output date for single variables or variable groups, as specified
# - the amount of variables depends on the model configuration
output_atm_vgrid=on         # 1 file/variable             , start date
output_atm_state_3d_ini=on  # 1 file/variable             , start_date
output_atm_state_3d_sim=on  # 1 file/all variables        , first_output_date to last__output_date
output_atm_state_2d_sim=on  # 1 file/all variables        , first_output_date to last__output_date
output_atm_tend_3d=off      # 1 file/variable/date        , first_output_date to last__output_date ! not created
output_atm_flux_2d=off       # 1 file/(variable group)/date, first_output_date to last__output_date ! not created
output_atm_rad_3d=off        # 1 file/ rad var lowest and highest level, instantaneous 
output_lnd=on
output_atm_mon=on            # 1 file/ global monthly mean values 
output_atm_hfreq=off


# output processes
num_io_procs=8


#--------------------------------------------------------------------------------------------------

# (2) Define the model configuration

# atmospheric dynamics and physics
# --------------------------------
# model time step
model_time_step="PT450S"       # 360 sec for R2B6, 120 sec for R3B7, 240 sec for R2B5
dtime=450                      # for use with parameterizations

ldynamics=.TRUE.    # .TRUE.: on       , .FALSE.: off
ltransport=.TRUE.   # .TRUE.: on       , .FALSE.: off
iforcing=3          #     2 : Sapphire ,  0     : off, 3 : NWP
nlev=130
atmo_model_equations=3  # equation system : nonhydrostatic
#

if [ ${iforcing} -eq 3 ]
then
dt_rad=3600.
dt_conv=$((dtime))
dt_sso=$((dtime))
dt_ccov=$((dtime))
dt_gwd=$((dtime))

run_jsbach=yes      # yes; jsbach with pfts

# land surface and soil
# ----------------------
#
if [ ${run_jsbach} = yes ]
then
jsb_case="'jsbach_pfts'"   # jsbach_lite or jsbach_pfts

if [ ${jsb_case} = "'jsbach_lite'" ]
then
npft=0
fract_filename="'bc_land_frac.nc'"
use_alb_veg_simple=.TRUE.
jsb_assimi_active=.FALSE.
jsb_pheno_scheme="'climatology'"
fi # ${jsb_case}

if [ ${jsb_case} = "'jsbach_pfts'" ]
then
npft=12
fract_filename="'bc_land_frac_${npft}pfts.nc'"
use_alb_veg_simple=.FALSE.
jsb_assimi_active=.TRUE.
jsb_pheno_scheme="'logrop'"
fi # ${jsb_case}
#
fi # ${run_jsbach}
#
fi # ${iforcing}

# atmo_namelist +++++++++++++++++++++++++++++++++++++++++++++++++
atmo_namelist=NAMELIST_atmo_${EXPNAME} # also used in exec.iconrun
#
cat > ${atmo_namelist} << EOF
!
&parallel_nml
 nproma            = ${nproma}
 nblocks_c         = ${nblocks_c}
 num_io_procs      = ${num_io_procs}
 iorder_sendrecv   = 3  
 use_omp_input     = .true.
/
&run_nml
 num_lev              = ${nlev}        ! number of full levels
 modelTimeStep        = '${model_time_step}'
 dtime                = ${dtime}
 ltestcase            = .FALSE.
 ldynamics            = ${ldynamics}
 ltransport           = ${ltransport}
 iforcing             = ${iforcing}
 output               = 'nml'
 msg_level            = 14
 restart_filename     = '${EXPNAME}_restart_atm_<rsttime>.mfr'
 activate_sync_timers = .TRUE.
 ntracer              = 5
/
&grid_nml
 dynamics_grid_filename = ${atmo_dyn_grids}
/
&sleve_nml
 min_lay_thckn   = 20.
 max_lay_thckn   = 500.   ! maximum layer thickness below htop_thcknlimit; un = 500; tvp = 400
 htop_thcknlimit = 35000. ! this implies that the upcoming COSMO-EU nest will have 60 levels
 top_height      = 75000.
 stretch_fac     = 1.2    ! un = 1.2; tvp = 0.9
 decay_scale_1   = 4000.
 decay_scale_2   = 2500.
 decay_exp       = 1.2
 flat_height     = 35000. ! un = 35000.; tvp = 16000
/
&extpar_nml
 extpar_filename         = "external_parameter_0012_R02B04_G_tiles.nc" 
 itopo                   = 1
 n_iter_smooth_topo      = 1
 pp_sso                  = 2
/
&initicon_nml
 init_mode             = 2            ! 2: IFS; 7: Initialized DWD Analysis
 zpbl1                 = 500.
 zpbl2                 = 1000.
 ifs2icon_filename     = "ifs2icon_1988010100_0012_R02B04_G.nc"
 filetype              = 4
/
EOF

# Dynamics
#--------------
if [ ${ldynamics} = '.TRUE.' ]
then
cat >> ${atmo_namelist} << EOF
!
&nonhydrostatic_nml
 iadv_rhotheta  = 2
 ivctype        = 2           ! Type of vertical grid; 2: sleve (default); 1: Gal-Chen hybrid
 htop_moist_proc= 22500.         
 hbot_qvsubstep = 16000.      ! 
 damp_height    = 50000.
 rayleigh_coeff = 0.5         !
 vwind_offctr   = 0.2
 divdamp_fac    = 0.004
 divdamp_trans_start = 12500.0
 divdamp_trans_end   = 17500.0
 exner_expol    = 0.5
 ndyn_substeps  = 8           ! dtime/dt_dyn
 divdamp_order  = 24          ! 2 ass, 24 fc : tvp = 24 : un = 4
 divdamp_type   = 32          ! Guenther recommended this optional: 2 for assimilation 
                              ! cycle if very strong gravity-wave filtering is required
                              ! optional: 2 assimilation cycle, 32 forecast
                              ! un = 3; tvp = 32      
 igradp_method  = 3           ! 3 (default value)
 l_zdiffu_t     = .true.      ! .true. : default value
 thslp_zdiffu   = 0.02
 thhgtd_zdiffu  = 125.
/
&dynamics_nml
 iequations     = ${atmo_model_equations}
 divavg_cntrwgt = 0.50        ! 0.5 (default): weight of central cell for divergence averaging
 lcoriolis      = .true.      ! .treu. (default): Coriolis force
 lmoist_thdyn   = .true.      ! default =.true. 
/
&diffusion_nml
 hdiff_order      = 5         ! 5(default)
 itype_vn_diffu   = 1	      ! 1 (default) 
 itype_t_diffu    = 2         ! 2 (default) 
 hdiff_efdt_ratio = 24.0      ! 36 (default)
 hdiff_smag_fac   = 0.025     ! default
 lhdiff_vn        = .TRUE.    ! default
 lhdiff_temp      = .TRUE.    ! default 
/
EOF
fi # ${ldynamics}

# Tracer and transport
# ---------------------
# 
if [ ${ltransport} = .TRUE. ]
then
cat >> ${atmo_namelist} << EOF
!
&transport_nml
 tracer_names       = 'qv', 'qc', 'qi', 'qr', 'qs'
 ivadv_tracer       = 3,3,3,3,3  ! 3 (default)
 itype_hlimit       = 3,4,4,4,4  ! 4 (default): type of limiter for horizontal transport
 ihadv_tracer       = 32,2,2,2,2 
 iadv_tke           = 0          ! Type of TKE advection; 0: no advection
/
EOF
fi # ${ltransport}

# Forcing
# -------
if [ ${iforcing} -eq 3 ]
then
#
cat >> ${atmo_namelist} << EOF
&nwp_phy_nml
 inwp_gscp              = 1
 inwp_convection        = 1
 inwp_radiation         = 4      ! 4 - ecrad, 1 - rrtm (old)
 inwp_cldcover          = 1
 inwp_turb              = 6      ! 1 - turbtran, 6 vdiff
 inwp_satad             = 1
 inwp_sso               = 1
 inwp_gwd               = 1
 inwp_surface           = 2       ! 1 - terra, 2 - jsbach
 icapdcycl              = 3       ! apply CAPE modification to improve diurnalcycle over 
!                                 ! tropical land (optimizes NWP scores)
 latm_above_top         = .false. ! the second entry refers to the nested domain (if present)
 efdt_min_raylfric      = 7200.   !un: 3600
 itype_z0               = 2
 icpl_aero_conv         = 1       
 icpl_aero_gscp         = 3       ! 3: check meaning -> default 0 - off, wo cdnc
 dt_rad                 = ${dt_rad}  
 dt_conv                = ${dt_conv}  
 dt_sso                 = ${dt_sso}
 dt_gwd                 = ${dt_gwd}
 dt_ccov                = ${dt_ccov}
 lconv_cdnc_interp      = .FALSE.  ! Cloud-num based interpolation
 scale_cdnc_mode        = 1   ! scale cdnc: time varying
 itype_parcel_ascent    = 2   ! 2: IFS/Cy41r2 (cubic/quadratic)
 itype_satpres_coeffs   = 2 
/
&nwp_tuning_nml
 tune_gust_factor = 7.0          ! neu ab L130_030 nach Trang
 max_calibfac_clcl= 2            ! neu ab L130_030 nach Trang
 itune_albedo     = 0            ! somewhat reduced albedo (w.r.t. MODIS data) 
!                                ! over Sahara in order to reduce cold bias
 tune_zceff_min   = 0.025        ! un:0.075 ! ** default value to be used for R3B7; 
!                                ! use 0.05 for R2B6 in order to get similar temperature 
!                                ! biases in upper troposphere **
 tune_gkdrag      = 0.065        ! gkdrag:  0.09 (R3B7),  0.075 (R2B6) -> estimate: 0.05 - 0.055 (R2B4)
 tune_gkwake      = 0.5          ! as:1.4, gkwake:  1.8  (R3B7),  1.5   (R2B6) -> estimate: 1.0  - 1.1   (R2B4)
 tune_gfrcrit     = 0.38         ! as:0.45; gfrcrit: 0.333 (R3B7), 0.425 (R2B6) -> estimate: 0.55 - 0.6   (R2B4)
 tune_grcrit      = 0.5          ! as: uncomment default:0.25
 tune_gkdrag_enh  = 0.09         ! as:default(0.075)
 tune_grcrit_enh  = 0.55         ! as:default(0.25)
 tune_box_liq_asy = 3.0
 tune_box_liq     = 0.05         ! new for sensitivity study
 tune_rcucov      = 0.075        ! neu ab L130_030 nach Trang
 tune_rhebc_land  = 0.825        ! neu ab L130_030 nach Trang
 lcalib_clcov     = .false.      ! neu ab L130_030 nach Trang : turn off TCC, HCC, MCC, LCC tuning
 !nach Trang Feb 2023
 tune_entrorg     = 0.00195
 tune_rprcon      = 0.0012       ! coefficient for conversion of cloud water 
!                                ! into precipitation  
 tune_zvz0i       = 0.85            ! new value for sensitivity study; last 1.2 - ab L130_30; 
!                                 ! 0.8 bis 027 nach Trang un: 1.1 
 tune_eiscrit     = 7.
 tune_sc_eis      = 7.
 !-------------------------------------------------------------
 !un: non-orographic gwd section
 tune_gfluxlaun   = 2.5e-3 ! default value
 tune_gcstar      = 2.      ! 
 !-------------------------------------------------------------
 tune_rmfdeps_land = 0.30 
 tune_rmfdeps_ocean= 0.25
/
&lnd_nml
 !-------------------------------	
 ! JSBACH settings	
 ntiles			= 1        ! 1 is default value 
 lseaice		= .true.   ! for use of thermodynamics of sea-ice model 
 sstice_mode		= 6        ! un: 6; =4: SST & sea-ice updated daily; =6: updated 
                                   ! with user-defined interval  
 sst_td_filename	= "sst_inst_mode.nc"
 ci_td_filename		= "sic_inst_mode.nc"         
 lprog_albsi		= .true.   ! sea-ice albedo is computed prognostically
 albsi_snow_max         = 0.8                ! not sure if this have to be set also for amip runs 
 albsi_snow_min         = 0.69 !0.78, def. 0.50         ! Minimum albedo of snow
 albsi_max              = 0.70 !def. 0.70       ! Maximum albedo of sea ice
 albsi_min              = 0.65 !def. 0.48       ! Minimum albedo of sea ice
 itype_heatcond         = 3
 llake                  = .false. ! JSBACH handles lake internally  
/
EOF


# Radiation
# ---------------

if [ x${dt_rad} != x ]
then
cat >> ${atmo_namelist} << EOF
!
&radiation_nml
 isolrad             = 2   ! new from L130_30 after Trang
