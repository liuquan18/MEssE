 ecrad_llw_cloud_scat = .true.     !
/
&ccycle_nml
 ccycle_config%iccycle  = 2
 ccycle_config%ico2conc = 4
/
EOF
fi # ${dt_rad}

#
# Vertical diffusion
# --------------------
# note: time step for vdiff is model_time_step
# vdiff is used with jsbach
cat >> ${atmo_namelist} << EOF
!
&turb_vdiff_nml
 fsl                    = 0.8       ! Fraction of the bottom level height where fluxes are formally evaluated.
