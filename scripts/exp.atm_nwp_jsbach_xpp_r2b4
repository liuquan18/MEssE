/
&jsb_seb_nml
  l_skin_temp 	       = .TRUE.           ! BC file should contain skin_conductivity variable
  bc_filename          = 'jsbach_bc_phys'
  ic_filename          = 'jsbach_ic_soil'
/
&jsb_rad_nml
  use_alb_veg_simple   = ${use_alb_veg_simple}    ! use true for jsbach_lite, false for jsbach_pfts
  bc_filename          = 'jsbach_bc_phys'
