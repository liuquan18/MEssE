add_link_file ${datadir}/bc_land_frac_12pfts_1988.nc     ./jsbach_lnd_frac 
add_link_file ${datadir}/ic_land_soil.nc                 ./jsbach_ic_soil
add_link_file ${datadir}/bc_land_phys.nc	         ./jsbach_bc_phys
add_link_file ${datadir}/bc_land_soil.nc	         ./jsbach_bc_soil 
add_link_file ${datadir}/bc_land_sso.nc  	         ./jsbach_sso     
#
fi # ${run_jsbach}

# Kinne aerosol, Volcanoes, Ozone, Greenhouse gases
# ----------------------------------------------------
# Kinne aerosols : background
# year independent data and icon-grid dependent

datadir=/pool/data/icon-xpp/0012/aerosol_kinne/r0001
add_link_file ${datadir}/bc_aeropt_kinne_sw_b14_coa.nc                  ./bc_aeropt_kinne_sw_b14_coa.nc
add_link_file ${datadir}/bc_aeropt_kinne_lw_b16_coa.nc                  ./bc_aeropt_kinne_lw_b16_coa.nc


# If using simple plumes for aerosol
# Link simple plumes: historical and SSP transient files are merged
# for simulations after 2020 chose the correct SSP file
datadir=${icon_data_rootFolder}/grids/public/mpim/independent/MACv2_simple_plumes_merged
add_link_file ${datadir}/MACv2.0-SP-merged-historical-and-SSP2-45_v1.nc ./MACv2.0-SP_v1.nc


# well mixed greenhouse gases
datadir=/pool/data/icon-xpp/common/greenhouse_gases
add_link_file ${datadir}/greenhouse_historical_plus.nc    ./bc_greenhouse_gases.nc


# Year dependent aerosols, volcanoes, ozone
# link time dependent aerosol and ozone data :
# assume start_date and end_date have the format yyyy-...
start_year=$(( ${start_date%%-*} - 1 ))
end_year=$(( ${end_date%%-*} + 1 ))

year=$start_year
while [[ $year -le $end_year ]]
do
    # year dependent and icon_grid dependent Kinne aerosol
    datadir=/pool/data/icon-xpp/0012/aerosol_kinne/r0001
    add_link_file ${datadir}/bc_aeropt_kinne_sw_b14_fin_${year}.nc      ./bc_aeropt_kinne_sw_b14_fin_${year}.nc

    # year dependent and icon_grid dependent ozone 
    datadir=/pool/data/icon-xpp/0012/ozone/r0001/
    add_link_file ${datadir}/bc_ozone_historical_${year}.nc             ./bc_ozone_${year}.nc

    # year dependent volcanoes
    datadir=/pool/data/icon-xpp/common/aerosol_volcanic_cmip7
    add_link_file ${datadir}/bc_aeropt_cmip7_volc_lw_b16_sw_b14_${year}.nc ./bc_aeropt_volc_lw_b14_${year}.nc

    # year dependent bc_land_frac_11pfts files
    datadir=/pool/data/icon-xpp/0012/aerosol_kinne/r0001
    add_link_file ${datadir}/bc_land_frac_12pfts_${year}.nc                ./bc_land_frac_12pfts_${year}.nc 
    
    (( year = year + 1 ))
done


# SST and sea ice
# ----------------------------
# 
datadir=/pool/data/icon-xpp/0012/sst_and_seaice/r0001
sst_file=${datadir}/SST_CMIP_PCMDI-AMIP-1-1-7_197801-202012_daily_0012_R02B04_G.nc
sic_file=${datadir}/SeaIce_CMIP_PCMDI-AMIP-1-1-7_197801-202012_daily_0012_R02B04_G.nc

add_link_file ${sst_file}  ./sst_inst_mode.nc
add_link_file ${sic_file}  ./sic_inst_mode.nc


#--------------------------------------------------------
# (4) Define the output: namelists for formats, files, variables

# Output formats
# --------------
#
# Parameters for all output files
# -------------------------------
cat >> ${atmo_namelist} << EOF
&io_nml
 itype_pres_msl     = 4     ! 5: new DWD method; 4: IFS method with bug fix for 
                            ! self-consistency between SLP and geopotential
 itype_rh           = 1     ! RH w.r.t. water; default value = 1
 precip_interval    = "P1D"
 maxt_interval      = "P1D"
 restart_write_mode = "joint procs multifile"
 lnetcdf_flt64_output = ${flt64_output}
 restart_file_type  = 5
/
&interpol_nml
 lsq_high_ord      = 3
 l_intp_c2l        = .true.
 l_mono_c2l        = .true.
 rbf_scale_mode_ll = 1
/
EOF


# Define output files
# -------------------

# vertical grid
# -----------------------------------------
# - constant in time
# - output at start_date only
#
if [ ${output_atm_vgrid} = on ]
then
#
# - all levels
#
varlist="'z_mc' 'z_ifc'"
#
for var in ${varlist}
do
cat >> ${atmo_namelist} << EOF
&output_nml
 output_filename  = '${EXPNAME}_${var//\'}'
 filename_format  = '${EXPNAME}_${var//\'}_ml'
 !ready_file       = '${EXPNAME}_${var//\'}_ml.ready'
 filetype         = ${output_format}
 remap            = 0
 output_grid      = ${output_grid}
 output_start     = '${start_date}'
 output_end       = '${start_date}'
 output_interval  = '${output_interval_3d}'
 file_interval    = '${file_interval}'
 ml_varlist       = ${var}         
/
EOF
done
#
fi # ${output_atm_vgrid}

#
# initial state of the atmosphere
# -------------------------------
# - instananeous values
# - output at start_date only
#
if [ ${output_atm_state_3d_ini} = on ]
then
#
# - all levels
#
varlist="'pres' 'temp' 'rho' 'u' 'v' 'w'"
for var in ${varlist}
do
  cat >> ${atmo_namelist} << EOF
&output_nml
 output_filename  = '${EXPNAME}_${var//\'}'
 filename_format  = '${EXPNAME}_${var//\'}_ml_<datetime2>'
 !ready_file       = '${EXPNAME}_${var//\'}_ml_<datetime2>.ready'
 filetype         = ${output_format}
 remap            = 0
 output_grid      = ${output_grid}
 output_start     = '${start_date}'
 output_end       = '${start_date}'
 output_interval  = '${output_interval_3d}'
 file_interval    = '${file_interval}'
 include_last     = .FALSE.
 ml_varlist       = ${var}
/
EOF
done
fi # ${output_atm_state_3d_ini}

# simulated atmospheric state
# ---------------------------
# - mean values 
# - from first_output_date to last__output_date 
